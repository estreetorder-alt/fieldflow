# Copy this to .env.local for local dev
# On Vercel, set these in Project Settings > Environment Variables

# Optional: email sending (Resend API)
# RESEND_API_KEY=re_xxxxxxxxxxxx

# Optional: a secret used for signing (future use)
# APP_SECRET=changeme

# Admin notification email
ADMIN_EMAIL=admin@snapect.com

# Ntfy.sh push notifications (free)
NTFY_TOPIC=snapect-alerts-yoursecretname
