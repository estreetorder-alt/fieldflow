# Copy this to .env.local for local dev
# On Vercel, set these in Project Settings > Environment Variables

# ── Required — Supabase (database) ──────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# ── Required for the site's real base URL (used in emails, invoices, Stripe redirects) ──
NEXT_PUBLIC_BASE_URL=https://your-domain.com

# ── Required for payments ────────────────────────────────────────
WHOP_API_KEY=your-whop-company-api-key
WHOP_COMPANY_ID=biz_xxxxxxxxxxxx
WHOP_WEBHOOK_SECRET=your-whop-webhook-signing-secret

# Optional: email sending (Resend API) — without this, emails are logged but not sent
RESEND_API_KEY=re_xxxxxxxxxxxx

# Optional: SMS notifications (Twilio) — without these, SMS is skipped/logged only
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxx
TWILIO_FROM_NUMBER=+15551234567

# Optional: address autocomplete/validation (Mapbox) — falls back to basic format check without it
MAPBOX_TOKEN=pk.xxxxxxxxxxxx

# Optional: Google reCAPTCHA v2 ("I'm not a robot" checkbox) on the login page
# Get free keys at https://www.google.com/recaptcha/admin — choose "Challenge (v2)" > "I'm not a robot" Checkbox
# If these are not set, the login page shows no CAPTCHA at all (rate limiting still applies)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=6Lxxxxxxxxxxxx
RECAPTCHA_SECRET_KEY=6Lxxxxxxxxxxxx

# Optional: a secret used for signing (future use)
# APP_SECRET=changeme

# Admin notification email
ADMIN_EMAIL=info@snapect.com

# Ntfy.sh push notifications (free)
NTFY_TOPIC=snapect-alerts-yoursecretname

